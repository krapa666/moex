#!/usr/bin/env bash
set -euo pipefail

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [[ -z "${branch}" || "${branch}" == "HEAD" ]]; then
  exit 0
fi

push_remote() {
  local remote="$1"
  if git remote get-url "$remote" >/dev/null 2>&1; then
    echo "[post-commit] pushing ${branch} -> ${remote}" >&2
    if ! GIT_TERMINAL_PROMPT=0 git push "$remote" "$branch"; then
      echo "[post-commit] warning: push to ${remote} failed" >&2
    fi
  fi
}

push_remote github
push_remote gitlab
